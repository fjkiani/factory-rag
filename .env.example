# --- OpenRouter (primary LLM + embeddings) ---
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
HTTP_REFERER=https://github.com/fjkiani/factory-rag
APP_TITLE=factory-rag-mvp

# --- Groq (secondary LLM, no embeddings) ---
GROQ_API_KEY=gsk_...
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# --- Models (swappable via env, all live-verified to return 200) ---
LLM_MODEL=openai/gpt-oss-120b:free
JUDGE_MODEL=openai/gpt-oss-20b:free
EMBED_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
EMBED_BACKEND=openrouter

# --- Vector store ---
VECTOR_BACKEND=numpy
QDRANT_URL=
QDRANT_API_KEY=

# --- Pipeline thresholds ---
ROUTE_CONF_THRESHOLD=0.35
RETRIEVAL_CONF_THRESHOLD=0.0

# --- Admin ---
ADMIN_TOKEN=change-me

# --- Storage ---
DATA_DIR=./data
