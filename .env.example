# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Models (swappable via env, no code change)
LLM_MODEL=openrouter/auto
JUDGE_MODEL=google/gemini-flash-1.5:free
EMBED_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# Vector store backend: numpy (MVP default) | qdrant (placeholder)
VECTOR_BACKEND=numpy
# Qdrant placeholders (unused when VECTOR_BACKEND=numpy)
QDRANT_URL=
QDRANT_API_KEY=

# Pipeline thresholds
ROUTE_CONF_THRESHOLD=0.5
RETRIEVAL_CONF_THRESHOLD=0.35

# Admin
ADMIN_TOKEN=change-me

# Storage
DATA_DIR=./data
